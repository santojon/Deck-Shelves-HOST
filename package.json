{
  "name": "@deck-shelves/host",
  "version": "1.1.0",
  "description": "Deck Shelves host contract — the HostApi types all host adapters and the bundle build against.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "upgrade": "node scripts/upgrade-pnpm.cjs && pnpm --version",
    "update": "pnpm update --latest && pnpm install",
    "update:check": "pnpm outdated || true",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "dev:check": "pnpm run check",
    "clean": "node scripts/clean.mjs",
    "release:dry": "pnpm run clean && pnpm run check && pnpm run build && pnpm pack --dry-run",
    "release:local": "pnpm run clean && pnpm run check && pnpm run build && pnpm pack",
    "prepublishOnly": "pnpm run clean && pnpm run check && pnpm run build"
  },
  "keywords": [
    "deck-shelves",
    "steam-deck",
    "steam",
    "host"
  ],
  "author": "Jonathan Santos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santojon/Deck-Shelves-HOST.git"
  },
  "bugs": {
    "url": "https://github.com/santojon/Deck-Shelves-HOST/issues"
  },
  "homepage": "https://github.com/santojon/Deck-Shelves-HOST#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": "^0.25.0",
      "vite": "^6.4.2",
      "form-data": "^4.0.6"
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0"
}
